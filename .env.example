# ============================================================================
# WORLVIEW OSINT - ENVIRONMENT CONFIGURATION
# ============================================================================

# ============================================================================
# REQUIRED: Google Maps Platform (for 3D Photorealistic Tiles)
# ============================================================================
# Without this key, the 3D city models won't load.
# 
# Get your API key:
# 1. Go to https://developers.google.com/maps/documentation/tile/get-api-key
# 2. Create a Google Cloud project
# 3. Enable "Map Tiles API"
# 4. Create an API key
# 5. Paste it below:
#
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ============================================================================
# OPTIONAL: Cesium Ion (alternative terrain/imagery)
# ============================================================================
# Get token at: https://cesium.com/ion/tokens
# VITE_CESIUM_ION_TOKEN=your_cesium_ion_token_here

# ============================================================================
# OPTIONAL: ADS-B Exchange (Military Aircraft Tracking)
# ============================================================================
# For real-time military aircraft data
# Get API key at: https://www.adsbexchange.com/price/
# ADSBEXCHANGE_API_KEY=your_adsb_exchange_key_here

# ============================================================================
# BACKEND CONFIGURATION
# ============================================================================

# Minimal mode (default) - no database needed
DATABASE_URL=memory://
REDIS_URL=memory://

# Or use SQLite for persistence:
# DATABASE_URL=sqlite:///./data/worldview.db

# Or use PostgreSQL (if installed):
# DATABASE_URL=postgresql://worldview:worldview@localhost:5432/worldview
# REDIS_URL=redis://localhost:6379

API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true

# ============================================================================
# OPTIONAL: Data Source API Keys
# ============================================================================

# OpenSky Network (civilian flights)
# OPENSKY_USERNAME=your_opensky_username
# OPENSKY_PASSWORD=your_opensky_password

# RIPE Atlas (network measurements)
# RIPE_ATLAS_API_KEY=your_ripe_atlas_key

# ============================================================================
# FRONTEND
# ============================================================================

VITE_API_URL=http://localhost:8000
VITE_GRAPHQL_URL=http://localhost:8000/graphql

# ============================================================================
# LOGGING
# ============================================================================

LOG_LEVEL=INFO
LOG_FORMAT=text
