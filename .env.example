# ============================================================================
# WORLDVIEW OSINT - ENVIRONMENT CONFIGURATION
# ============================================================================
# Copy this file to .env.local and fill in your values

# ============================================================================
# CONVEX (Required)
# ============================================================================
# Your Convex deployment URL - get this from your Convex dashboard
# For local dev: https://your-deployment.convex.cloud
# For production: https://your-prod-deployment.convex.cloud
CONVEX_URL=https://your-deployment.convex.cloud
VITE_CONVEX_URL=https://your-deployment.convex.cloud
CONVEX_DEPLOYMENT=dev:your-deployment

# ============================================================================
# GOOGLE MAPS (Required for 3D Tiles)
# ============================================================================
# Without this, 3D photorealistic buildings won't load
# Get your API key: https://developers.google.com/maps/documentation/tile/get-api-key
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ============================================================================
# OPENSKY NETWORK (Required for flight data)
# ============================================================================
# Get free account at: https://opensky-network.org/
OPENSKY_USERNAME=your_opensky_email
OPENSKY_PASSWORD=your_opensky_password

# ============================================================================
# OPTIONAL: CESIUM ION
# ============================================================================
# For better satellite imagery and terrain
# Get token at: https://cesium.com/ion/tokens
# VITE_CESIUM_ION_TOKEN=your_cesium_ion_token_here

# ============================================================================
# OPTIONAL: ADS-B EXCHANGE (Military aircraft)
# ============================================================================
# VITE_ADSBEXCHANGE_API_KEY=your_adsb_exchange_key_here
